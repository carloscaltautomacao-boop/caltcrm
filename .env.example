# ===== IA (OpenAI) =====
OPENAI_API_KEY=sk-...

# ===== Banco (Supabase Postgres) =====
# String completa de conexao, SEM query params extras.
DATABASE_URL=postgresql://postgres:senha@db.xxxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...

# ===== Evolution API (gateway WhatsApp) =====
EVO_URL=https://sua-evolution.com
EVO_INSTANCE=calt
EVO_APIKEY=apikey-da-instancia
GLOBAL_EVO_APIKEY=apikey-global-do-servidor

# ===== App =====
# URL publica do deploy (usada para configurar o webhook do Evolution).
VITE_APP_URL=http://localhost:5173
# Segredo do JWT do painel (>= 32 chars). Gere com: openssl rand -base64 48
JWT_SECRET=troque-por-um-segredo-aleatorio-com-32-chars-ou-mais

# ===== Admin inicial (criado no primeiro boot se a tabela users estiver vazia) =====
ADMIN_INITIAL_EMAIL=admin@calt.com.br
ADMIN_INITIAL_PASSWORD=troque-no-primeiro-login

# ===== Contatos de handoff (acionamento humano) =====
# Numero do WhatsApp que recebe a notificacao quando a IA aciona o humano.
HANDOFF_WHATSAPP_CARLOS=5586999999999
# Numero de vendas/indicacoes pessoais.
HANDOFF_WHATSAPP_RAYANE=5586988888888

# ===== Cron (regua de follow-up) =====
# Segredo que protege /api/cron/agenda. A Vercel injeta este valor no header das chamadas de cron.
# Definir o MESMO valor no painel da Vercel (Settings -> Environment Variables). Gere com: openssl rand -hex 32
CRON_SECRET=troque-por-um-segredo-aleatorio
